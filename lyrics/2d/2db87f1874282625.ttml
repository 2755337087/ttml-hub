<?xml version='1.0' encoding='utf-8'?><tt xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" itunes:timing="Word" xml:lang="zh-Hans"><head><metadata><ttm:agent type="person" xml:id="v1"><ttm:name type="full">王赫野</ttm:name></ttm:agent><ttm:agent type="person" xml:id="v2"><ttm:name type="full">喻言</ttm:name></ttm:agent><ttm:agent type="group" xml:id="v1000"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><songwriters><songwriter>Покатаев Артур Рафикович</songwriter></songwriters><translations><translation type="subtitle" xml:lang="zh-Hans"><text for="L1">拿走我的心</text><text for="L2">而我会拿走你的心</text><text for="L3">我们两个人相伴在一起</text><text for="L4">一起去往某个地方</text><text for="L27">我无处可去 也无处可逃</text><text for="L28">前路错综复杂 我无法保持沉默</text><text for="L29">我是多么爱你</text><text for="L30">书本里无法写尽</text><text for="L31">梦境中也无法想象</text><text for="L32">只能用心去感受</text><text for="L37">拿走我的心</text><text for="L38">而我会拿走你的心</text><text for="L39">我们两个人相伴在一起</text><text for="L40">一起去往某个地方</text><text for="L41">拿走我的心</text><text for="L42">并将它好好珍藏</text><text for="L43">无论发生什么</text><text for="L44">都不要放手</text></translation></translations></iTunesMetadata><amll:meta key="ttmlAuthorGithub" value="76586484"/><amll:meta key="ttmlAuthorGithubLogin" value="2755337087"/><amll:meta key="musicName" value="别让爱凋落 (Live)"/><amll:meta key="musicName" value="别让爱凋落 (Live版)"/><amll:meta key="artists" value="王赫野"/><amll:meta key="artists" value="喻言"/><amll:meta key="album" value="天赐的声音第六季 第5期"/><amll:meta key="album" value="天赐的声音第六季 第5期 (Live)"/><amll:meta key="qqMusicId" value="001eNuyG35jW7p"/><amll:meta key="ncmMusicId" value="2704605090"/><amll:meta key="appleMusicId" value="1816775844"/></metadata></head><body><div begin="0:20.600" end="0:30.752" itunes:songPart="Intro"><p begin="0:20.600" end="0:22.891" itunes:key="L1